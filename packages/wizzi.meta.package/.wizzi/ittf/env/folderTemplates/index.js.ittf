$group
    $if metaCtx.useEnv
        $file __dot__wizzi/env/yyy.js.ittf.ittf
            module
                kind es6
                ${'$'}include env/xxx.js
        $
            var items = [
                "alpha",
                "beta",
            ];
        $foreach item in items
            $file __dot__wizzi/t/env/${metaVer}/${item}.js.ittf.ittf
                $group
                    ${'$'}include env/tfolder/${item}.js

$group
    $if metaCtx.usePackage
        $file __dot__wizzi/package/yyy.js.ittf.ittf
            module
                kind es6
                ${'$'}include package/xxx.js
        $
            var items = [
                "alpha",
                "beta",
            ];
        $foreach item in items
            $file __dot__wizzi/t/package/${metaVer}/${item}.js.ittf.ittf
                $group
                    ${'$'}include package/tfolder/${item}.js

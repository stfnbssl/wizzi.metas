$group
    $if metaCtx.useDeply
        $file __dot__wizzi/deply/yyy.js.ittf.ittf
            module
                kind es6
                ${'$'}include deply/xxx.js
        $
            var items = [
                "alpha",
                "beta",
            ];
        $foreach item in items
            $file __dot__wizzi/t/deply/${metaVer}/${item}.js.ittf.ittf
                $group
                    ${'$'}include deply/tfolder/${item}.js

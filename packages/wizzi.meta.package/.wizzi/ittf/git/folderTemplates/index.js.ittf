$group
    $if metaCtx.useGit
        $file __dot__wizzi/git/yyy.js.ittf.ittf
            module
                kind es6
                ${'$'}include git/xxx.js
        $
            var items = [
                "alpha",
                "beta",
            ];
        $foreach item in items
            $file __dot__wizzi/t/git/${metaVer}/${item}.js.ittf.ittf
                $group
                    ${'$'}include git/tfolder/${item}.js

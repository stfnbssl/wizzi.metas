$group
    $if metaCtx.useBabel
        $file __dot__wizzi/babel/yyy.js.ittf.ittf
            module
                kind es6
                ${'$'}include babel/xxx.js
        $
            var items = [
                "alpha",
                "beta",
            ];
        $foreach item in items
            $file __dot__wizzi/t/babel/${metaVer}/${item}.js.ittf.ittf
                $group
                    ${'$'}include babel/tfolder/${item}.js

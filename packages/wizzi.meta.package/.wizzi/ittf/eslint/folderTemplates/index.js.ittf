$group
    $if metaCtx.useEslint
        $file __dot__wizzi/eslint/yyy.js.ittf.ittf
            module
                kind es6
                ${'$'}include eslint/xxx.js
        $
            var items = [
                "alpha",
                "beta",
            ];
        $foreach item in items
            $file __dot__wizzi/t/eslint/${metaVer}/${item}.js.ittf.ittf
                $group
                    ${'$'}include eslint/tfolder/${item}.js

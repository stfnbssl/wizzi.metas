$group

    $if metaCtx.tsExpressFeaturePacki.usePackiEdit
        
        $file __dot__wizzi/${pkgPath}src/features/packiEdit/index.ts.ittf.ittf
            module
                ${'$'}include tsExpressFeaturePacki/packi-edit/index.ts
        
        $file __dot__wizzi/${pkgPath}src/features/packiEdit/types.ts.ittf.ittf
            module
                ${'$'}include tsExpressFeaturePacki/packi-edit/types.ts

        $file __dot__wizzi/${pkgPath}src/features/packiEdit/controllers/localedit.tsx.ittf.ittf
            module
                ${'$'}include tsExpressFeaturePacki/packi-edit/controllers/localedit.tsx

        $file __dot__wizzi/${pkgPath}src/features/packiEdit/controllers/apiv1local.ts.ittf.ittf
            module
                ${'$'}include tsExpressFeaturePacki/packi-edit/controllers/apiv1local.ts

        $file __dot__wizzi/${pkgPath}src/features/packiEdit/api/packiEdit.ts.ittf.ittf
            module
                ${'$'}include tsExpressFeaturePacki/packi-edit/api/packiEdit.ts


$group
    $if metaCtx.useWizziCommons
        $
            var items = [
                "executegenerateModelDoms",
                "executeWizziJob",
                "fileInfoByPath",
                "getIttfFilesBySchema",
                "loadModelAndGenerateArtifact",
                "loadModelAndGenerateArtifactFromText",
                "loadModelAndTransform",
                "loadMTree",
                "loadMTreeBuildupScript",
                "loadWizziModel",
                "loadWizziModelAndSaveToJson"
            ];

        $foreach item in items
            
            $file __dot__wizzi/t/wizzicommons/opers/${item}.js.ittf.ittf
                ${"${'$'}"}group
                    ${'$'}include wizziCommons/tfolder/opers/${item}.js


        $file __dot__wizzi/t/wizzicommons/globals/defaultMimeTypes.js.ittf.ittf
            ${"${'$'}"}group
                ${'$'}include wizziCommons/tfolder/globals/defaultMimeTypes.js                    


